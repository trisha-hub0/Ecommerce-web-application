@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shopzy</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ShopzyWeb.styles.css" asp-append-version="true" />
</head>
<body>

    <!-- DEBUG (optional – remove later) -->
    

    <!-- ✅ NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">

                <!-- LOGO -->
                <a class="navbar-brand fw-bold" asp-page="/Index">
                    Shopzy
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">

                    <ul class="navbar-nav ms-auto">

                        <!-- COMMON -->
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Categories/Index">Categories</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Products/Index">Products</a>
                        </li>

                        <!-- ✅ USER ONLY (NOT ADMIN) -->
                        @if (Context.Session.GetInt32("UserId") != null &&
                                                Context.Session.GetString("IsAdmin") != "true")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Cart/Index">
                                    Cart
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Orders/Index">
                                    My Orders
                                </a>
                            </li>
                        }

                        <!-- ✅ ADMIN ONLY -->
                        @if (Context.Session.GetString("IsAdmin") == "true")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Admin/Dashboard/Index">
                                    Dashboard
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Admin/Orders/Index">
                                    Orders
                                </a>
                            </li>
                        }

                        <!-- LOGOUT (ANY LOGGED-IN USER) -->
                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-page="/Account/Logout">
                                    Logout
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <!-- ✅ MAIN CONTENT -->
    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- ✅ FOOTER -->
    <footer class="border-top footer text-muted mt-5">
        <div class="container text-center">
            &copy; 2026 - Shopzy
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

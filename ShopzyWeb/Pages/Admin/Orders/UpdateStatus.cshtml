@page
@model ShopzyWeb.Pages.Admin.Orders.UpdateStatusModel
@using ShopzyWeb.Models

<h2>Update Order Status</h2>

<form method="post">
    <input type="hidden" asp-for="Order.Id" />

    <div class="mb-3">
        <label class="form-label">Current Status</label>
        <input class="form-control"
               value="@Model.Order.Status"
               disabled />
    </div>

    <div class="mb-3">
        <label asp-for="Order.Status" class="form-label">New Status</label>

        <!-- ✅ ADMIN STATUS OPTIONS (NO CANCELLED) -->
        <select asp-for="Order.Status" class="form-select">
            @if (Model.Order.Status == OrderStatus.Pending)
            {
                <option value="@OrderStatus.Pending">Pending</option>
                <option value="@OrderStatus.Shipped">Shipped</option>
            }
            else if (Model.Order.Status == OrderStatus.Shipped)
            {
                <option value="@OrderStatus.Shipped">Shipped</option>
                <option value="@OrderStatus.Delivered">Delivered</option>
            }
            else if (Model.Order.Status == OrderStatus.Delivered)
            {
                <option value="@OrderStatus.Delivered">Delivered</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">
        Update Status
    </button>

    <a asp-page="Index" class="btn btn-secondary ms-2">
        Back
    </a>
</form>

@page
@model ShopzyWeb.Pages.Admin.IndexModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container my-5">

    <h2 class="text-center fw-bold mb-5">Admin Dashboard</h2>

    <div class="row g-4 justify-content-center">

        <div class="col-md-4">
            <div class="card shadow-sm text-center p-4">
                <h5>Add Category</h5>
                <p class="text-muted">Create product categories</p>
                <a asp-page="/Categories/Create"
                   class="btn btn-primary">
                    Add Category
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm text-center p-4">
                <h5>Add Product</h5>
                <p class="text-muted">Add new products</p>
                <a asp-page="/Products/Create"
                   class="btn btn-success">
                    Add Product
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm text-center p-4">
                <h5>Manage Products</h5>
                <p class="text-muted">Edit / Delete products</p>
                <a asp-page="/Products/Index"
                   class="btn btn-dark">
                    View Products
                </a>
            </div>
        </div>

    </div>

</div>

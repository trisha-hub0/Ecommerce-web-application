@page
@model ShopzyWeb.Pages.Cart.IndexModel

<h2 class="mb-4">Your Cart</h2>

@if (!Model.Cart.Any())
{
    <div class="alert alert-info">Your cart is empty.</div>
}
else
{
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Product</th>
                <th class="text-center">Qty</th>
                <th class="text-end">Price</th>
                <th class="text-end">Total</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Cart)
            {
                <tr>
                    <td>
                        <img src="@item.ImageUrl" width="50" class="me-2 rounded" />
                        @item.Title
                    </td>

                    <td class="text-center">

                        <form method="post" asp-page-handler="Minus" class="d-inline">
                            <input type="hidden" name="id" value="@item.ProductId" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">−</button>
                        </form>

                        <span class="mx-2">@item.Count</span>

                        <form method="post" asp-page-handler="Plus" class="d-inline">
                            <input type="hidden" name="id" value="@item.ProductId" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">+</button>
                        </form>

                    </td>

                    <td class="text-end">₹ @item.Price</td>

                    <td class="text-end">
                        ₹ @(item.Price* item.Count)
                    </td>

                    <td class="text-end">
                        <form method="post" asp-page-handler="Remove">
                            <input type="hidden" name="id" value="@item.ProductId" />
                            <button type="submit" class="btn btn-sm btn-danger">
                                Remove
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="text-end fw-bold fs-5 mt-3">
        Grand Total: ₹ @Model.Cart.Sum(c => c.Price * c.Count)
    </div>

    <div class="text-end mt-4">
        <a asp-page="Checkout" class="btn btn-success btn-lg">
            Proceed to Checkout
        </a>
    </div>
}